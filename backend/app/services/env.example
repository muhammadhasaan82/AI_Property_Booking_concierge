# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_CHAT_MODEL=gpt-5-nano
OPENAI_TEMPERATURE=0.3
OPENAI_TOP_P=0.95
OPENAI_TOP_K=50
OPENAI_FREQUENCY_PENALTY=
OPENAI_PRESENCE_PENALTY=
OPENAI_MAX_TOKENS=

# Database Configuration
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_KEY=your_service_role_or_legacy_key_here
SUPABASE_DB_URL=your_supabase_connection_string_here
SUPABASE_DB_HOST=127.0.0.1
SUPABASE_DB_PORT=54322
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=your_database_password_here

#Mem0
MEM0_VECTOR_STORE=chroma
MEM0_COLLECTION_NAME=ai_concierge_memories
MEM0_STORAGE_DIR=backend/.mem0
MEM0_LLM_PROVIDER=groq
MEM0_LLM_MODEL=llama-3.3-70b-versatile
MEM0_EMBEDDER_PROVIDER=huggingface
MEM0_EMBEDDER_MODEL=BAAI/bge-large-en-v1.5
MEM0_TIMEOUT=3.0
MEM0_SEARCH_LIMIT=5

# Vector Database
CHROMA_DIR=./chroma
EMBED_MODEL=BAAI/bge-large-en-v1.5
CHROMA_COLLECTION=properties

# Dataset Configuration
DATASET_PATH=./services/dataset.csv
DATASET_FORMAT=csv




# Server Configuration
PORT=8000
HOST=127.0.0.1

# LLM Settings
LLM_STRUCTURED=1
SOFT_INTENT_ROUTER=1

# Rust Gateway Configuration
RUST_GATEWAY_URL=http://localhost:3001
RUST_TIMEOUT=5.0

# Redis session store
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL_SECONDS=86400
ADK_SESSION_MAX_EVENTS=12
ADK_SESSION_MAX_CONTEXT_CHARS=12000
ADK_MAX_COGNITIVE_CONTEXT_CHARS=3000

#chainlit UI
CHAINLIT_AUTH_SECRET="your_secret_auth"

# ── ADK 2.0 V2 Brain (Phase 2) ──────────────────────────────────────────────
# Set ADK_ENABLED=0 to fall back to the V1 LangGraph pipeline
ADK_ENABLED=1

# Dispatcher (Node 1: Triage Router) — ultra-fast, routing-only
# Hyperparams: temperature=0.3, top_p=0.95, top_k=50 (enforced in code)
ADK_DISPATCHER_MODEL=openai/gpt-5-nano

# Voice (Node 2: Concierge Voice) — empathetic response formatting
ADK_VOICE_MODEL=groq/llama-3.3-70b-versatile

# Groq API key (required for Llama-3.3-70B via LiteLLM)
GROQ_API_KEY=your_groq_api_key_here

# Windows only: prevents LiteLLM UnicodeDecodeError on cached files
PYTHONUTF8=1

# ── Phase 3: Telemetry, Anomaly Detection & DPO ─────────────────────────────
# DPO trajectory logging (SQLite primary + Supabase mirror)
DPO_TELEMETRY_ENABLED=1
DPO_SQLITE_PATH=dpo_telemetry.db

# Tool-loop anomaly detection
ANOMALY_TOOL_LOOP_THRESHOLD=3
ANOMALY_SESSION_TTL_MINUTES=30

# Rust gateway rate limiter (per-IP sliding window)
RUST_RATE_LIMIT_MAX=10
RUST_RATE_LIMIT_WINDOW_SECS=10

LITELLM_TELEMETRY="False"
LITELLM_LOG="ERROR"
